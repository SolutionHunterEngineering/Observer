    private async Task Logout()
    {
        currentUserId = 0;
        isAdmin = false;
        isDesigner = false;
        isTrialUser = false;
        isUser = false;
        welcomeName = string.Empty;
        CacheSvc.SetUserLoginStatus(false);
        Toggle("solutionhunter");
    }

    private async void HandleEnterKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Login();
        }
    }
}
