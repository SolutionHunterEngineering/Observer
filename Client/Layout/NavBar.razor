@* Observer NavBar with toggleable sub-buttons *@
<nav class="navbar px-3 d-flex justify-content-between" style="background-color: #0a5746; color: white;">
    <div class="d-flex align-items-center gap-4">
        <a class="navbar-brand text-white" href="/">Observer v1.0</a>

        <button class="btn text-white dropdown-toggle ms-4" type="button"
                @onclick="ToggleConnectionPanel"
                style="background-color: #850f1a;">
            Connections
        </button>
    </div>

    <div class="d-flex align-items-center gap-2">
        <label class="text-white me-1" for="usernameInput">User Name</label>
        <input type="text" id="usernameInput" class="form-control form-control-sm" placeholder="user name" style="width: 120px;" />

        <label class="text-white mx-2" for="passwordInput">Password</label>
        <input type="password" id="passwordInput" class="form-control form-control-sm" placeholder="password" style="width: 120px;" />

        <NavLink class="btn text-white ms-3" style="background-color: #850f1a;" href="/login">Login</NavLink>
    </div>
</nav>

@if (showConnectionPanel)
{
    <div class="connection-submenu">
        <button class="btn btn-outline-light mx-2">Subject</button>
        <button class="btn btn-outline-light mx-2">Servers</button>
        <button class="btn btn-outline-light mx-2">Links</button>
    </div>
}

@code {
    private bool showConnectionPanel = false;

    private void ToggleConnectionPanel()
    {
        showConnectionPanel = !showConnectionPanel;
    }
}
